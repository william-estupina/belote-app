{
  "name": "@belote/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "node ./scripts/lancer-expo.cjs start",
    "dev:web": "node ./scripts/lancer-expo.cjs start --web --host lan",
    "dev:android": "node ./scripts/lancer-expo.cjs start --android",
    "dev:ios": "node ./scripts/lancer-expo.cjs start --ios",
    "verifier:bundle:android": "expo export:embed --eager --platform android --dev false",
    "build:android": "eas build --platform android",
    "build:android:apk": "eas build --platform android --profile preview",
    "build:ios": "eas build --platform ios",
    "test": "jest",
    "test:e2e": "npx expo export --platform web && npx playwright test",
    "test:e2e:headed": "npx expo export --platform web && npx playwright test --headed",
    "typecheck": "tsc --noEmit",
    "lint": "eslint app/ components/ hooks/ stores/"
  },
  "dependencies": {
    "@belote/bot-engine": "workspace:*",
    "@belote/game-logic": "workspace:*",
    "@belote/shared-types": "workspace:*",
    "@expo/metro-runtime": "~6.1.2",
    "@shopify/react-native-skia": "2.2.12",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "metro-runtime": "^0.84.2",
    "react": "19.1.4",
    "react-dom": "19.1.4",
    "react-native": "~0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.2",
    "xstate": "^5",
    "zustand": "^4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/react-native": "^12",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.17",
    "@types/sharp": "^0.32.0",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "babel-preset-expo": "^54.0.10",
    "jest": "^29",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "^19.1.0",
    "serve": "^14.2.6",
    "sharp": "^0.34.5",
    "typescript": "^5.7"
  }
}
