{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "packages/game-logic": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/bot-engine": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/shared-types": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/mobile": {
      "entry": ["app/**/*.{ts,tsx}"],
      "project": ["**/*.{ts,tsx}"]
    }
  }
}
